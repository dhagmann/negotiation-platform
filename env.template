# Environment Variables Template
# Copy this file to .env and replace with your actual values
# NEVER commit .env to Git!

# Demo Mode (set to true to run without a database)
# DEMO_MODE=true

# PostgreSQL Database Configuration
DB_HOST=your-database-host.rds.amazonaws.com
DB_USER=your_db_user
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_NAME=your_database_name
DB_PORT=5432

# Alternative: Full connection URL (choose one method)
# POSTGRES_DATABASE_URL=postgresql://your_db_user:YOUR_PASSWORD_HERE@your-database-host.rds.amazonaws.com:5432/your_database_name

# Application Configuration
NODE_ENV=production
DB_MAX_CONNECTIONS=200
DB_MIN_CONNECTIONS=0
DB_CACHE_TIMEOUT=30
